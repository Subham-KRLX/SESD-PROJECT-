{
  "name": "sesd-project-",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev:backend": "node --loader ts-node/esm src/index.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "npm run dev:backend & npm run dev:frontend",
    "seed": "node --loader ts-node/esm prisma/seed.ts",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc",
    "build:frontend": "npm ci --prefix frontend && npm run build --prefix frontend",
    "start": "node dist/index.js",
    "postinstall": "prisma generate",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:backend": "jest src",
    "test:frontend": "cd frontend && npm test && cd ..",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma migrate dev --skip-generate",
    "db:studio": "prisma studio",
    "validate": "npm run type-check && npm run lint && npm run build && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Subham-KRLX/SESD-PROJECT-.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/Subham-KRLX/SESD-PROJECT-/issues"
  },
  "homepage": "https://github.com/Subham-KRLX/SESD-PROJECT-#readme",
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^6.19.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6"
  }
}
